OPENAI_API_KEY=

# Real product search is the normal runtime path.
CATALOG_PROVIDER=openai
OPENAI_RESEARCH_MODEL=gpt-5.4-mini
OPENAI_RESEARCH_TIMEOUT_SECONDS=90

# Intent extraction can be enabled independently.
INTENT_PROVIDER=mock
OPENAI_INTENT_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_FALLBACK_TO_MOCK=true

COMPARISON_PROVIDER=mock
OPENAI_COMPARISON_MODEL=gpt-5-mini
PAYMENTS_PROVIDER=mock
