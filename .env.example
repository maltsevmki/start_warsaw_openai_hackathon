# Keep actual credentials only in the ignored .env file.
INTENT_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_FALLBACK_TO_MOCK=true

# Checkout payments: "mock" (deterministic, offline) or "stripe" (real test-mode).
PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_TEST_PAYMENT_METHOD=pm_card_visa
